\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces  \textbf  {Difference between a trap set and a trap space.} A state space of a BN with $n=3$ is shown. The BN contains two attractors: a steady state $A_1$ (a blue state 000) and an oscillatory attractor $A_2$ (red states $1\ensuremath  {{*}}\ensuremath  {{*}}$). The trap set $S$ (double-shaded are) is also a trap space as it can be described by a subspace $00\ensuremath  {{*}}$. On the other hand, the trap set $X$ (shaded area) is not a trap space as it cannot be described by a subspace. Notice, that also a set of all states $\ensuremath  {{*}}\ensuremath  {{*}}\ensuremath  {{*}}$ is a trap space (set), even though it contains multiple attractors. \relax }}{12}{figure.caption.9}\protected@file@percent }
\newlabel{fig:traps}{{4}{12}{\textbf {Difference between a trap set and a trap space.} A state space of a BN with $n=3$ is shown. The BN contains two attractors: a steady state $A_1$ (a blue state 000) and an oscillatory attractor $A_2$ (red states $1\unspecified \unspecified $). The trap set $S$ (double-shaded are) is also a trap space as it can be described by a subspace $00\unspecified $. On the other hand, the trap set $X$ (shaded area) is not a trap space as it cannot be described by a subspace. Notice, that also a set of all states $\unspecified \unspecified \unspecified $ is a trap space (set), even though it contains multiple attractors. \relax }{figure.caption.9}{}}
\newlabel{fig:traps@cref}{{[figure][4][]4}{[1][12][]12}}
