\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces  \textbf  {Difference between a strong and a weak basin.} The figure shows a simple STG with two attractors: a steady state $A_1$ (dark red) and an oscillatory attractor $A_2$ (dark blue). Strong basins of $A_1$ and $A_2$ are shown in light red and light blue, respectively and are disjoint. Finally, the weak basin of $A_1$ and $A_2$ are shown in red and blue stripes, respectively. The weak basins overlap as some states can reach multiple attractors. \relax }}{14}{figure.caption.10}\protected@file@percent }
\newlabel{fig:basins}{{5}{14}{\textbf {Difference between a strong and a weak basin.} The figure shows a simple STG with two attractors: a steady state $A_1$ (dark red) and an oscillatory attractor $A_2$ (dark blue). Strong basins of $A_1$ and $A_2$ are shown in light red and light blue, respectively and are disjoint. Finally, the weak basin of $A_1$ and $A_2$ are shown in red and blue stripes, respectively. The weak basins overlap as some states can reach multiple attractors. \relax }{figure.caption.10}{}}
\newlabel{fig:basins@cref}{{[figure][5][]5}{[1][13][]14}}
